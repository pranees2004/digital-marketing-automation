# ============================================================
#  DIGITAL MARKETING AUTOMATION — SAMPLE ENV FILE
#  Copy this file:  cp .env.sample .env
#  Then fill in your real values below
# ============================================================

# ===================== CLAUDE API ============================
# Get your API key from: https://console.anthropic.com/
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7

# ===================== AZURE SERVICES ========================
# Azure Portal: https://portal.azure.com
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_RESOURCE_GROUP=digital-marketing-rg
AZURE_TENANT_ID=your-azure-tenant-id

# --- Cosmos DB ---
# Create: Azure Portal > Cosmos DB > Create > NoSQL
AZURE_COSMOS_ENDPOINT=https://your-cosmos-db-name.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-primary-key-here
AZURE_COSMOS_DATABASE=marketing_db

# --- Blob Storage ---
# Create: Azure Portal > Storage Accounts > Create
AZURE_STORAGE_CONNECTION=your-azure-storage-connection-string-here
AZURE_STORAGE_CONTAINER=marketing-assets

# --- Key Vault ---
# Create: Azure Portal > Key Vault > Create
AZURE_KEYVAULT_URL=https://your-keyvault-name.vault.azure.net/

# --- Communication Services (for email) ---
# Create: Azure Portal > Communication Services > Create
AZURE_COMMUNICATION_CONNECTION=your-azure-communication-connection-string-here

# ===================== COMPANY PROFILE =======================
# Customize these to match YOUR company
COMPANY_NAME=Acme Digital Solutions
COMPANY_INDUSTRY=Technology / SaaS
COMPANY_WEBSITE=https://yourcompany.com
TARGET_AUDIENCE=B2B SaaS decision makers, CTOs, marketing managers aged 28-55
BRAND_VOICE=Professional yet approachable, data-driven, innovative, trustworthy
UNIQUE_VALUE_PROPOSITION=We help mid-market companies automate their growth with AI-powered marketing

# Comma-separated lists
KEY_PRODUCTS=AI Marketing Suite,Analytics Dashboard,Content Optimizer,Lead Generator
COMPETITORS=HubSpot,Marketo,Mailchimp,SEMrush

# ===================== SOCIAL MEDIA — TWITTER/X ==============
# Get from: https://developer.twitter.com/en/portal
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ===================== SOCIAL MEDIA — META ====================
# Get from: https://developers.facebook.com/
META_ACCESS_TOKEN=your-meta-access-token
META_PAGE_ID=your-facebook-page-id
META_INSTAGRAM_ACCOUNT_ID=your-instagram-business-account-id
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ===================== SOCIAL MEDIA — LINKEDIN ================
# Get from: https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_ORGANIZATION_ID=your-linkedin-organization-id

# ===================== GOOGLE SERVICES ========================
# Setup: https://console.cloud.google.com/
GOOGLE_ANALYTICS_PROPERTY_ID=properties/123456789
GOOGLE_ADS_CUSTOMER_ID=123-456-7890
GOOGLE_SEARCH_CONSOLE_SITE=https://yourcompany.com
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json

# ===================== EMAIL ==================================
EMAIL_SENDER_ADDRESS=marketing@yourcompany.com
EMAIL_REPLY_TO=hello@yourcompany.com
EMAIL_DAILY_LIMIT=500

# ===================== REDIS ==================================
# Local: redis://localhost:6379/0
# Azure Redis: your-azure-redis-connection-string
REDIS_URL=redis://localhost:6379/0

# ===================== APPLICATION ============================
DEBUG=True
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4

# ===================== OPTIONAL — WEBHOOKS ====================
# Paste your Slack incoming webhook URL here
SLACK_WEBHOOK_URL=your-slack-webhook-url-here
# Paste your Teams incoming webhook URL here
TEAMS_WEBHOOK_URL=your-teams-webhook-url-here

# ===================== SCHEDULING =============================
# Cron expressions for automated tasks
DAILY_CONTENT_SCHEDULE=08:00
DAILY_SOCIAL_SCHEDULE=09:00,12:00,17:00
WEEKLY_SEO_AUDIT_DAY=monday
WEEKLY_REPORT_DAY=friday
MONTHLY_REPORT_DAY=1
TIMEZONE=UTC
