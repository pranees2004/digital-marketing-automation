# ============================================================
# DIGITAL MARKETING AUTOMATION — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values
# ============================================================

# ===== CLAUDE API =====
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ===== AZURE SERVICES =====
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=digital-marketing-rg
AZURE_COSMOS_ENDPOINT=https://your-db.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-primary-key
AZURE_COSMOS_DATABASE=marketing_db
AZURE_STORAGE_CONNECTION=DefaultEndpointsProtocol=https;AccountName=yourstorage;AccountKey=xxx;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=marketing-assets
AZURE_KEYVAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_COMMUNICATION_CONNECTION=endpoint=https://your-comm.communication.azure.com/;accesskey=xxx

# ===== COMPANY PROFILE =====
COMPANY_NAME=YourCompany
COMPANY_INDUSTRY=Technology
COMPANY_WEBSITE=https://yourcompany.com
TARGET_AUDIENCE=B2B SaaS decision makers aged 25-55
BRAND_VOICE=Professional, innovative, data-driven, approachable
UNIQUE_VALUE_PROPOSITION=We help businesses scale with AI-powered solutions

# ===== SOCIAL MEDIA — TWITTER/X =====
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ===== SOCIAL MEDIA — META (Facebook/Instagram) =====
META_ACCESS_TOKEN=your-meta-access-token
META_PAGE_ID=your-facebook-page-id
META_INSTAGRAM_ACCOUNT_ID=your-instagram-business-account-id

# ===== SOCIAL MEDIA — LINKEDIN =====
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_ORGANIZATION_ID=your-linkedin-org-id

# ===== GOOGLE SERVICES =====
GOOGLE_ANALYTICS_PROPERTY_ID=properties/xxxxx
GOOGLE_ADS_CUSTOMER_ID=xxx-xxx-xxxx
GOOGLE_SEARCH_CONSOLE_SITE=https://yourcompany.com
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ===== EMAIL =====
EMAIL_SENDER_ADDRESS=marketing@yourcompany.com
EMAIL_REPLY_TO=hello@yourcompany.com

# ===== REDIS (for Celery task queue) =====
REDIS_URL=redis://localhost:6379/0

# ===== APPLICATION =====
DEBUG=True
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
